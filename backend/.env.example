# --- Required ---
OPENAI_API_KEY=sk-...    # general agents (intake, fall_risk, reinjury_risk, reporter, progress)
GEMINI_API_KEY=AIza...   # exercise_reporter agent — Google AI Studio → aistudio.google.com

# --- Optional (these defaults work for local dev) ---
# DATABASE_URL=sqlite+aiosqlite:///./sentinel_dev.db   # default
# JWT_SECRET=dev-secret-change-in-prod                 # default
# CHROMA_PERSIST_DIR=./chroma_db                       # default
# DEV_MODE=true                                        # default — skips JWT auth

# --- Production overrides ---
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/sentinel
# JWT_SECRET=long-random-secret
# DEV_MODE=false

# --- uAgents (optional, only needed if using Agentverse) ---
# AGENTVERSE_MAILBOX_KEY=your-key
